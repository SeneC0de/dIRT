# SQLite board state (per-Director runtime, not source code)
**/board.db
**/board.db-journal
**/board.db-wal
**/board.db-shm
**/*.db
**/*.db-journal
**/*.db-wal
**/*.db-shm

# Periodic snapshot exports
**/board.json

# Python cache
**/__pycache__/
*.pyc

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
# GCP service account key - never commit
gcp-key.json
*.json.key
# Real per-user config (uses gcp_config.example.json as template)
gcp_config.json
# Legacy SQLite board state (any leftover from pre-Firestore)
# Built dashboard output (regenerated by web/build.py on every firebase deploy)
web/public/

# Firebase CLI local cache (created by `firebase deploy`)
web/.firebase/

user.json

# Scratch directory for runtime agent files (ADR drafts, intermediate results)
.work/

# Head git worktrees — created on demand by Director dispatches, not source code.
# (Per agents/director.md "Head lifecycle"; these accumulate and pollute git status.)
.claude/worktrees/

# Stale dashboard hosting refs — should not be in dIRT anymore (moved to dASH),
# but keep the ignores in case a worktree creates them.
web/public/
web/.firebase/

# Customer document intake — raw docs stay local; only structure + AI-extracted
# derivatives (under extracted/) commit. Confidential by default.
_intake/*/drawings/**
_intake/*/boms/**
_intake/*/config-sheets/**
_intake/*/pos/**
_intake/*/rfqs/**
_intake/*/invoices/**
_intake/*/order-acks/**
_intake/*/jobs/**
!_intake/**/.gitkeep
!_intake/**/README.md
